/*
  Cache-Control: public, max-age=0, must-revalidate

/resources/*
  Cache-Control: public, max-age=31536000
  Expires: access plus 1 year

*.css
*.js
  Cache-Control: public, max-age=31536000, immutable
  Expires: access plus 1 year

/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Expires: access plus 1 minute